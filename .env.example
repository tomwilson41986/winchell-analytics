# Frontend (Vite) — set these in Netlify build environment too.
# Without them the site still works: subscriptions stay in-browser only.

# Supabase project (Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push VAPID *public* key (generate the pair with:
#   npx web-push generate-vapid-keys
# the private key goes into GitHub Actions secrets, never here)
VITE_VAPID_PUBLIC_KEY=
