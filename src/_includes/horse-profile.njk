---
layout: base.njk
---

<div class="horse-profile">
  <div class="horse-profile-header">
    <h1>{{ title }}</h1>
    <div class="horse-profile-meta">
      <span>{{ color }} {{ sex }}</span>
      <span>Foaled {{ foaled }}</span>
      <span class="horse-status status-{{ status | lower | replace(' ', '-') }}">{{ status }}</span>
    </div>
  </div>
  <div class="horse-profile-body">
    <div class="info-grid">
      <div class="info-item">
        <div class="label">Sire</div>
        <div class="value">{{ sire }}</div>
      </div>
      <div class="info-item">
        <div class="label">Dam</div>
        <div class="value">{{ dam }}</div>
      </div>
      <div class="info-item">
        <div class="label">Trainer</div>
        <div class="value">{{ trainer }}</div>
      </div>
      <div class="info-item">
        <div class="label">Status</div>
        <div class="value">{{ status }}</div>
      </div>
    </div>
    <div class="profile-content content-body">
      {{ content | safe }}
    </div>
  </div>
</div>
