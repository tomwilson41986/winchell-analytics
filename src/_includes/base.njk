<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Winchell Analytics</title>
  <meta name="description" content="{{ description or 'Horse racing analytics by Winchell' }}">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-logo">
        <span class="logo-mark">W</span>
        <span class="logo-text">Winchell Analytics</span>
      </a>
      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="hamburger"></span>
      </button>
      <nav class="main-nav" id="main-nav">
        <ul class="nav-list">
          <li class="nav-item has-dropdown">
            <a href="/horses/" class="nav-link">Horses</a>
            <ul class="dropdown">
              <li><a href="/horses/in-training/">In Training</a></li>
              <li><a href="/horses/workout-reports/">Workout Reports</a></li>
            </ul>
          </li>
          <li class="nav-item has-dropdown">
            <a href="/sales/" class="nav-link">Sales</a>
            <ul class="dropdown">
              <li><a href="/sales/historic-sales/">Historic Sales</a></li>
            </ul>
          </li>
          <li class="nav-item has-dropdown">
            <a href="/sectional-data/" class="nav-link">Sectional &amp; Stride Data</a>
            <ul class="dropdown">
              <li><a href="/sectional-data/stride-data/">Stride Data</a></li>
            </ul>
          </li>
        </ul>
      </nav>
    </div>
  </header>

  {% block breadcrumb %}
  {% if breadcrumb %}
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol>
        <li><a href="/">Home</a></li>
        {% for crumb in breadcrumb %}
          {% if crumb.url %}
            <li><a href="{{ crumb.url }}">{{ crumb.label }}</a></li>
          {% else %}
            <li aria-current="page">{{ crumb.label }}</li>
          {% endif %}
        {% endfor %}
      </ol>
    </div>
  </nav>
  {% endif %}
  {% endblock %}

  <main class="site-main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>&copy; 2026 Winchell Analytics. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Mobile nav toggle
    const toggle = document.querySelector('.nav-toggle');
    const nav = document.querySelector('#main-nav');
    if (toggle && nav) {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', !expanded);
        nav.classList.toggle('is-open');
      });
    }
  </script>
</body>
</html>
